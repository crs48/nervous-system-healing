---
/** One optional disclosure level, invitational (0007). Never for essential content. */
interface Props {
  label?: string;
}
const { label = "Curious? Go deeper →" } = Astro.props;
---

<details
  class="rounded-card bg-[var(--surface-panel)]/60 p-4 my-6 open:shadow-soft max-w-[65ch]"
>
  <summary class="cursor-pointer font-medium text-[var(--heading)]">
    {label}
  </summary>
  <div class="pt-3 space-y-3"><slot /></div>
</details>
