---
/** Many doors, one room (0009). A static, reduced-motion-safe orienting
    figure: different modalities are different doors onto the same settled
    state — some free and trainable, some a borrowed visit. Tokens only. */
import { url } from "../lib/url";

const groups = [
  {
    heading: "Free & trainable",
    note: "Yours to keep",
    tone: "bg-sage-100 text-moss-800",
    doors: [
      { label: "A longer exhale", href: "practices/long-exhale/" },
      { label: "Hold, tense, and release", href: "practices/hold-and-release/" },
      { label: "Orienting", href: "practices/orienting/" },
    ],
  },
  {
    heading: "With a guide",
    note: "A practitioner",
    tone: "bg-cream-100 text-ink",
    doors: [
      { label: "Bodywork & co-regulation", href: "modalities/bodywork-myofascial/" },
    ],
  },
  {
    heading: "Clinical or borrowed",
    note: "A visit, not capacity",
    tone: "bg-rose-300/40 text-ink",
    doors: [
      { label: "Ketamine", href: "modalities/ketamine/" },
      { label: "Psychedelics", href: "modalities/classic-psychedelics/" },
    ],
  },
];
---

<figure
  class="not-prose my-6 max-w-[65ch] rounded-card bg-[var(--surface-raised)] p-6 shadow-soft"
>
  <figcaption class="font-display text-[var(--heading)] text-lg mb-1">
    Many doors, one room
  </figcaption>
  <p class="text-[var(--text-muted)] text-sm mt-0 mb-4">
    Different approaches are different doors onto the same settled state. Some
    you can open yourself, today. Some give a visit — capacity is what lets you
    return on your own.
  </p>

  <div class="grid gap-3 sm:grid-cols-3">
    {
      groups.map((g) => (
        <div class="rounded-soft border border-sage-200 p-3">
          <p class="m-0 font-bold text-[0.95rem]">{g.heading}</p>
          <p class="mt-0 mb-2 text-xs text-[var(--text-muted)]">{g.note}</p>
          <ul class="list-none p-0 m-0 space-y-1">
            {g.doors.map((d) => (
              <li>
                <a
                  href={url(d.href)}
                  class={`inline-block rounded-full px-2.5 py-0.5 text-sm no-underline ${g.tone}`}
                >
                  {d.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <p
    class="mt-4 mb-0 text-center font-display text-[var(--heading)]"
    aria-hidden="true"
  >
    ↓
  </p>
  <p class="mt-1 mb-0 text-center text-[var(--heading)]">
    one settled, regulated state — the room they all open onto
  </p>
</figure>
