---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Lead from "../../components/Lead.astro";
import NextSteps from "../../components/NextSteps.astro";
import { url } from "../../lib/url";

const entries = (await getCollection("garden")).sort(
  (a, b) => a.data.planted.getTime() - b.data.planted.getTime(),
);
---

<Base
  title="Understand"
  description="Plain-language explainers about nervous system states, capacity, and how slow change actually happens."
  crumbs={[{ label: "home", href: "" }]}
>
  <h1 class="text-3xl sm:text-4xl">Understand</h1>
  <Lead>
    A small, growing set of plain-language explainers. Each one can be read on
    its own, and each opens with a short version you can stop after. There's
    no need to read them in order, or all at once.
  </Lead>

  <ul class="list-none p-0 mt-6 space-y-3 max-w-[65ch]">
    {
      entries.map((e) => (
        <li>
          <a
            href={url(`learn/${e.id}/`)}
            class="block rounded-card bg-[var(--surface-raised)] p-5 shadow-soft no-underline hover:shadow-lift transition-shadow duration-300"
          >
            <p class="font-display text-lg text-[var(--heading)] m-0">
              {e.data.title}
            </p>
            <p class="mt-1 mb-0 text-[var(--text-muted)]">
              {e.data.description}
            </p>
          </a>
        </li>
      ))
    }
  </ul>

  <NextSteps>
    <li><a href={url("start/")}>New here? Start with the path</a></li>
    <li><a href={url("practices/")}>Or try a practice</a></li>
    <li><a href={url("")}>Back home</a></li>
  </NextSteps>
</Base>
