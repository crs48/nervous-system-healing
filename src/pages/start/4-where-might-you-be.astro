---
import Base from "../../layouts/Base.astro";
import Lead from "../../components/Lead.astro";
import StepNav from "../../components/StepNav.astro";
import StateCheckIn from "../../components/StateCheckIn.astro";
---

<Base
  title="Where might you be right now?"
  description="Step four: a gentle, optional two-slider check-in to help you locate roughly where your nervous system is."
  crumbs={[
    { label: "home", href: "" },
    { label: "start here", href: "start/" },
  ]}
>
  <h1 class="text-3xl sm:text-4xl">Where might you be, right now?</h1>
  <Lead>
    This is optional, and it's just a mirror — not a test or a diagnosis. Two
    small sliders can help you put rough words to where your system is at this
    moment, and point you toward practices that tend to suit that place.
    Nothing is saved, and you can skip straight ahead if you'd rather.
  </Lead>

  <div class="mt-6">
    <StateCheckIn />
  </div>

  <StepNav step={4} />
</Base>
